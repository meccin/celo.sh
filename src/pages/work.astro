---
import Layout from "../layouts/Layout.astro";
import { workExperience } from "../assets/data.ts";
---

<Layout>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <h1 class="text-4xl font-bold text-foreground mb-4">Work Experience</h1>
        <p class="text-muted-foreground mb-12">My journey as a developer.</p>

        <div class="space-y-8">
            {
                workExperience.map((job) => (
                    <div class="border-l-2 border-primary pl-6 pb-8 last:pb-0">
                        <h3 class="text-xl font-semibold text-foreground">
                            {job.title}
                        </h3>
                        <p class="text-primary text-sm font-medium mb-1">
                            {job.company}
                        </p>
                        <p class="text-muted-foreground text-sm mb-4">
                            {job.period}
                        </p>
                        <p class="text-muted-foreground">{job.description}</p>

                        {job.highlights && (
                            <ul class="mt-3 space-y-1">
                                {job.highlights.map((highlight) => (
                                    <li class="text-muted-foreground text-sm">
                                        • {highlight}
                                    </li>
                                ))}
                            </ul>
                        )}
                    </div>
                ))
            }
        </div>
    </div>
</Layout>
